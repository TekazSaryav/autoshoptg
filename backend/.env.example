# Patek Shop - Environment Variables

# MongoDB
MONGO_URL=mongodb://localhost:27017
DB_NAME=patek_shop

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
ADMIN_TELEGRAM_IDS=123456789
STAFF_TELEGRAM_IDS=

# Shop Settings
SHOP_NAME=Patek Shop
SHOP_CURRENCY=EUR

# Crypto Payment Addresses
BTC_ADDRESS=your_btc_address
LTC_ADDRESS=your_ltc_address

# API Security
INTERNAL_API_KEY=generate_a_secure_random_key_minimum_16_chars
RATE_LIMIT_PER_MINUTE=30
